{
  "name": "vervet",
  "version": "2026.03.0",
  "description": "A desktop Mongo DB tool",
  "productName": "Vervet",
  "author": "Sean Garrett <sean@blacktau.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "bunx --bun eslint -c ./eslint.config.ts \"./src*/**/*.{ts,js,cjs,mjs,vue}\" && bunx --bun vue-tsc --noEmit --strict",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest",
    "dev": "bunx --bun vite",
    "build": "bunx --bun vue-tsc --noEmit && bunx --bun vite build",
    "preview": "bunx --bun vite preview"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "chart.js": "^4.5.1",
    "color": "^5.0.3",
    "copy-text-to-clipboard": "^3.2.2",
    "dayjs": "^1.11.20",
    "highlight.js": "^11.11.1",
    "lodash": "^4.17.23",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "sass": "^1.98.0",
    "vue": "^3.5.30",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.3.0",
    "wcwidth": "^1.0.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vicons/tabler": "^0.13.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "~10.5.1",
    "jiti": "^2.6.1",
    "naive-ui": "^2.44.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-icons": "^22.5.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.3.1",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "dompurify": "^3.3.3",
    "vue-template-compiler": "npm:@vue/compiler-sfc@^3.5.30"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
